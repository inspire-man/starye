{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "Bundler",
    "types": ["@cloudflare/workers-types", "node"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "ignoreDeprecations": "6.0"
  },
  "references": [
    { "path": "../../packages/db" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "**/*.test.ts"]
}
