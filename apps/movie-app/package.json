{
  "name": "@starye/movie-app",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --port 3001",
    "build": "vue-tsc -b && vite build --config vite.config.ts --configLoader runner",
    "preview": "vite preview --port 3001",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "playwright:install": "playwright install chromium --with-deps"
  },
  "dependencies": {
    "@sentry/vue": "^10.53.1",
    "@starye/api-types": "workspace:*",
    "@starye/config": "workspace:*",
    "@starye/ui": "workspace:*",
    "hono": "^4.12.14",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.8.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "xgplayer": "^3.0.24"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
