# Cloudflare Pages SPA 路由配置
# 所有请求都应该返回 index.html（除了静态资源）

# 静态资源直接返回（带有正确的 MIME type）
/dashboard/assets/*  /dashboard/assets/:splat  200
/dashboard/*.js      /dashboard/:splat         200
/dashboard/*.css     /dashboard/:splat         200
/dashboard/*.svg     /dashboard/:splat         200
/dashboard/*.png     /dashboard/:splat         200
/dashboard/*.jpg     /dashboard/:splat         200
/dashboard/*.ico     /dashboard/:splat         200

# 所有其他路径返回 index.html（SPA fallback）
/dashboard/*         /dashboard/index.html     200
