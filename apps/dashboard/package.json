{
  "name": "dashboard",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@starye/db": "workspace:*",
    "@starye/locales": "workspace:*",
    "@starye/ui": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "hono": "^4.12.9",
    "lucide-vue-next": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "vis-network": "^10.0.2",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@starye/api-types": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.9",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.6"
  }
}
