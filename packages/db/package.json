{
  "name": "@starye/db",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "drizzle-kit generate",
    "d1-migrate": "tsx ../../scripts/target-remote-entry.ts --entry d1-migrate",
    "d1-migrate-movies-metadata": "tsx ../../scripts/target-remote-entry.ts --entry d1-migrate-movies-metadata",
    "d1-cleanup-backup-preview": "tsx ../../scripts/target-remote-entry.ts --entry d1-cleanup-backup-preview",
    "d1-cleanup-backup-execute": "tsx ../../scripts/target-remote-entry.ts --entry d1-cleanup-backup-execute",
    "d1-cleanup-invalid-covers": "tsx ../../scripts/target-remote-entry.ts --entry d1-cleanup-invalid-covers",
    "d1-smoke-snapshot": "tsx ../../scripts/target-remote-entry.ts --entry d1-smoke-snapshot",
    "studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "nanoid": "^5.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
