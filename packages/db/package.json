{
  "name": "@starye/db",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "echo '提示：D1 数据库迁移请使用 wrangler 命令：' && echo '本地: cd apps/api && wrangler d1 migrations apply starye-db --local' && echo '生产: cd apps/api && wrangler d1 migrations apply starye-db --remote'",
    "migrate:actors": "tsx scripts/migrate-actors-publishers.ts",
    "sync:actors": "tsx scripts/sync-actors-publishers.ts",
    "clean-data": "tsx scripts/clean-data.ts",
    "cleanup:preview": "tsx scripts/cleanup-backup-fields.ts --preview",
    "cleanup:execute": "tsx scripts/cleanup-backup-fields.ts --execute",
    "cleanup:covers": "tsx scripts/cleanup-invalid-covers.ts",
    "studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260413.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
