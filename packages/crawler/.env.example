# R2 Configuration
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=xxx-media
R2_PUBLIC_URL=https://cdn.xxx.org

# API Configuration
API_URL=http://localhost:8787
CRAWLER_SECRET=crawler_sk_test_12345678

# Puppeteer
# CHROME_PATH=/usr/bin/google-chrome-stable

# ==========================================
# JavBus Crawler Configuration
# ==========================================

# **REQUIRED**: Maximum number of movies to crawl (no default, must be set)
MAX_MOVIES=200

# Maximum number of pages to crawl (default: 5)
MAX_PAGES=10

# Use random mirror site (default: false)
USE_RANDOM_MIRROR=true

# Concurrency settings
LIST_CONCURRENCY=1
DETAIL_CONCURRENCY=2
IMAGE_CONCURRENCY=3
API_CONCURRENCY=2

# Delay settings (milliseconds)
LIST_DELAY=10000
DETAIL_DELAY=6000
IMAGE_DELAY=3000
API_DELAY=1000

# Display settings
SHOW_PROGRESS=true
SHOW_STATS=true
STATS_INTERVAL=60000

# ==========================================
# Comic Crawler Configuration
# ==========================================

# Concurrency control
CRAWLER_MANGA_CONCURRENCY=2          # Manga-level concurrency (default: 2)
CRAWLER_CHAPTER_CONCURRENCY=2        # Chapter-level concurrency (default: 2)
CRAWLER_IMAGE_BATCH=10               # Image batch upload size (default: 10)

# Limits
CRAWLER_MAX_MANGAS=60                # Max mangas per run (default: 15)
CRAWLER_MAX_CHAPTERS_NEW=5           # Max chapters for new manga (default: 5)
CRAWLER_MAX_CHAPTERS_UPDATE=20       # Max chapters for updating manga (default: 20)

# Soft timeout (minutes)
CRAWLER_TIMEOUT_MINUTES=350          # Soft timeout in minutes (default: 300)

# Anti-detection configuration
CRAWLER_BASE_DELAY=8000              # Base delay in ms (default: 8000)
CRAWLER_MAX_RETRIES=3                # Max retries for failed requests (default: 3)
CRAWLER_ENABLE_SESSION=true          # Enable session management (default: true)
