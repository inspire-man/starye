{
  "name": "@starye/crawler",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "crawl:comic": "tsx ../../scripts/target-remote-entry.ts --entry crawler-comic",
    "crawl:optimized": "tsx ../../scripts/target-remote-entry.ts --entry crawler-optimized",
    "crawl:actor": "tsx ../../scripts/target-remote-entry.ts --entry crawler-actor",
    "crawl:publisher": "tsx ../../scripts/target-remote-entry.ts --entry crawler-publisher",
    "build:search": "tsx ../../scripts/target-remote-entry.ts --entry crawler-search-index",
    "crawl:enrich-players": "tsx ../../scripts/target-remote-entry.ts --entry crawler-enrich-players",
    "check-config": "tsx ../../scripts/target-remote-entry.ts --entry crawler-check-config",
    "crawl:backfill-covers": "tsx ../../scripts/target-remote-entry.ts --entry crawler-backfill-covers",
    "crawl:backfill-publishers": "tsx ../../scripts/target-remote-entry.ts --entry crawler-backfill-publishers",
    "crawl:enrich-players-javbus": "tsx ../../scripts/target-remote-entry.ts --entry crawler-enrich-players-javbus",
    "audit:r2-storage": "tsx ../../scripts/target-remote-entry.ts --entry crawler-r2-storage-audit",
    "local:test-anti-detection": "tsx scripts/test-anti-detection.ts",
    "local:seesaawiki-index": "tsx src/scripts/crawl-seesaawiki-index.ts",
    "local:test-seesaawiki": "tsx scripts/test-seesaawiki-integration.ts",
    "local:diagnose-seesaawiki": "tsx scripts/diagnose-seesaawiki-parser.ts",
    "test": "vitest",
    "test:unit": "vitest run",
    "local:test-auth": "tsx scripts/test-api-auth.ts",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/lib-storage": "^3.1031.0",
    "@orama/orama": "^3.1.18",
    "@starye/db": "workspace:*",
    "cacheable-lookup": "^7.0.0",
    "cheerio": "^1.2.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.45.2",
    "got": "^15.0.2",
    "got-scraping": "^4.2.1",
    "iconv-lite": "^0.7.2",
    "p-map": "^7.0.4",
    "p-queue": "^9.1.2",
    "puppeteer-core": "^24.41.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@starye/config": "workspace:*",
    "@types/cli-progress": "^3.11.6",
    "@types/got": "^9.6.12",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "happy-dom": "^20.9.0",
    "puppeteer": "^24.41.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
