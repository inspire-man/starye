{
  "name": "starye-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Starye Personal Website Monorepo",
  "author": "",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:gateway": "pnpm --filter gateway dev",
    "dev:clean": "pnpm clean:ports && pnpm dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint-staged": "lint-staged",
    "clean": "turbo run clean",
    "clean:ports": "pwsh -ExecutionPolicy Bypass -File ./scripts/clean-ports.ps1 -Force",
    "check:services": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-services.ps1",
    "test": "turbo run test",
    "test:e2e": "vitest run test/e2e/flow.test.ts",
    "type-check": "turbo run type-check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  }
}
