{
  "name": "starye-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Starye Personal Website Monorepo",
  "author": "",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/local-dev.ts",
    "dev:gateway": "pnpm --filter gateway dev",
    "dev:clean": "pnpm clean:ports && pnpm dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint-staged": "lint-staged",
    "clean": "turbo run clean",
    "clean:ports": "pwsh -ExecutionPolicy Bypass -File ./scripts/clean-ports.ps1 -Force",
    "check:services": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-services.ps1",
    "test": "turbo run test",
    "test:e2e": "vitest run test/e2e/flow.test.ts",
    "target-profile": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/target-profile.ts",
    "target-deploy": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/target-deploy.ts",
    "target-remote-entry": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/target-remote-entry.ts",
    "smoke:data-chain": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/data-chain-smoke.ts",
    "smoke:data-chain-observe": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/data-chain-surface-observation.ts",
    "smoke:data-chain:verify": "pnpm --filter @starye/crawler exec node --import tsx ../../scripts/verify-data-chain-smoke.ts",
    "type-check": "turbo run type-check",
    "docs:sync": "pwsh -ExecutionPolicy Bypass -File ./scripts/sync-docs.ps1",
    "docs:meta": "node scripts/generate-meta.js",
    "docs:index": "node scripts/generate-sections.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@cloudflare/workers-types": "^4.20260417.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.90.0"
  }
}
